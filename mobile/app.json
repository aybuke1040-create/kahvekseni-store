{
  "expo": {
    "name": "KAHVEKSENİ",
    "slug": "kahvekseni",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "kahvekseni",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#3B1F0A"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kahvekseni.app",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Hesabınıza hızlı giriş için Face ID kullanabilirsiniz."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#3B1F0A"
      },
      "package": "com.kahvekseni.app",
      "permissions": ["USE_BIOMETRIC", "USE_FINGERPRINT"]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-local-authentication",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#C8963E"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
