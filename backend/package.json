    "db:seed": "ts-node prisma/seed.ts",
    "db:import:products": "ts-node prisma/import-products.ts",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
