# Required
DATABASE_URL="postgresql://kahvekseni:password@localhost:5432/kahvekseni_db"
JWT_SECRET="change_me_jwt_secret"
JWT_REFRESH_SECRET="change_me_refresh_secret"
WEB_URL="http://localhost:3000"
IYZICO_API_KEY="sandbox-api-key"
IYZICO_SECRET_KEY="sandbox-secret-key"

# Optional (defaults exist in code)
PORT=5000
NODE_ENV="development"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
POINTS_PER_TL=1
IYZICO_BASE_URL="https://sandbox-api.iyzipay.com"
PAYMENT_CALLBACK_URL="http://localhost:5000/api/payment/callback"
